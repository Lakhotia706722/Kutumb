NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/kutumb

# JWT — use a long random string in production, e.g. openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Cookie
# 🚩 PRODUCTION: set COOKIE_DOMAIN to your actual domain, e.g. yourdomain.com
#    and set COOKIE_SECURE=true (requires HTTPS)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS — comma-separated list of allowed frontend origins
# 🚩 PRODUCTION: set to your Vercel frontend URL, e.g. https://kutumb.vercel.app
CORS_ORIGINS=http://localhost:3000

# File storage (local | s3) — only "local" implemented in MVP
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=uploads

# Alert cron schedule (UTC). Default: 01:30 UTC = 07:00 IST
# https://crontab.guru for syntax
ALERT_CRON_SCHEDULE=30 1 * * *
